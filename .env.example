# Get these from platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Get these from console.twilio.com (your dashboard home)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (the one you bought)
TWILIO_PHONE_NUMBER=+15125550000

# Where to send calls when human help is needed (your personal/staff number)
TRANSFER_NUMBER=+15125559999

# Port (leave as 3000 for local dev)
PORT=3000
